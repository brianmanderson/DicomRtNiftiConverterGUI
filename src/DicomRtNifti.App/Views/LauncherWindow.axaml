<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Dicom_RT_images_Csharp.Views.LauncherWindow"
        Title="DICOM RT Toolkit" Width="480" Height="320"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#F5F5F5">

  <Grid RowDefinitions="Auto,*">

    <!-- Header bar -->
    <Border Grid.Row="0" Background="#3F51B5" Padding="16,12">
      <StackPanel>
        <TextBlock Text="DICOM RT Toolkit" FontSize="18" FontWeight="Bold" Foreground="White"/>
        <TextBlock Text="Pick a workflow to begin" FontSize="12" Foreground="#C5CAE9" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>

    <!-- Workflow buttons -->
    <Grid Grid.Row="1" Margin="20" RowDefinitions="*,*">

      <Button Grid.Row="0" Command="{Binding OpenDicomToNiftiCommand}"
              Margin="0,0,0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
              Background="#1976D2" Foreground="White" BorderThickness="0">
        <StackPanel Margin="14,8">
          <TextBlock Text="DICOM → NIfTI" FontSize="16" FontWeight="SemiBold"/>
          <TextBlock FontSize="11" Foreground="#E3F2FD" TextWrapping="Wrap" Margin="0,4,0,0"
                     Text="Convert DICOM RT-STRUCT, CT/MR/PT image series, and RT-DOSE into NIfTI files."/>
        </StackPanel>
      </Button>

      <Button Grid.Row="1" Command="{Binding OpenNiftiToDicomCommand}"
              Margin="0,10,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
              Background="#3F51B5" Foreground="White" BorderThickness="0">
        <StackPanel Margin="14,8">
          <TextBlock Text="NIfTI → DICOM" FontSize="16" FontWeight="SemiBold"/>
          <TextBlock FontSize="11" Foreground="#E8EAF6" TextWrapping="Wrap" Margin="0,4,0,0"
                     Text="Convert NIfTI image, masks, and dose back into standards-compliant DICOM (batch)."/>
        </StackPanel>
      </Button>
    </Grid>
  </Grid>
</Window>
