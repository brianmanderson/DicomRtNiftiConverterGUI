<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Dicom_RT_images_Csharp.Views.OutputSpacingWindow"
        Title="Output Spacing" Width="420" Height="360"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F5F5F5">

  <Grid RowDefinitions="Auto,*,Auto">

    <Border Grid.Row="0" Background="#9C27B0" Padding="16,10">
      <TextBlock Text="Output Voxel Spacing" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
    </Border>

    <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD"
            BorderThickness="1" CornerRadius="4" Margin="12,12,12,0" Padding="16">
      <StackPanel>
        <TextBlock Text="Specify the output voxel size in millimeters. All exported images, doses, and structure masks will be resampled to this spacing."
                   TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#555555"/>

        <Grid Margin="0,0,0,8" ColumnDefinitions="40,*,40">
          <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" FontWeight="Medium"/>
          <TextBox Grid.Column="1" x:Name="XTextBox" VerticalContentAlignment="Center" Padding="6,4" BorderBrush="#CCCCCC"/>
          <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#555555"/>
        </Grid>

        <Grid Margin="0,0,0,8" ColumnDefinitions="40,*,40">
          <TextBlock Grid.Column="0" Text="Y:" VerticalAlignment="Center" FontWeight="Medium"/>
          <TextBox Grid.Column="1" x:Name="YTextBox" VerticalContentAlignment="Center" Padding="6,4" BorderBrush="#CCCCCC"/>
          <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#555555"/>
        </Grid>

        <Grid Margin="0,0,0,8" ColumnDefinitions="40,*,40">
          <TextBlock Grid.Column="0" Text="Z:" VerticalAlignment="Center" FontWeight="Medium"/>
          <TextBox Grid.Column="1" x:Name="ZTextBox" VerticalContentAlignment="Center" Padding="6,4" BorderBrush="#CCCCCC"/>
          <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#555555"/>
        </Grid>

        <!-- Inline validation message (replaces the WPF MessageBox popups). -->
        <TextBlock x:Name="ErrorText" Foreground="#D32F2F" FontSize="12" TextWrapping="Wrap"
                   IsVisible="False" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC"
            BorderThickness="0,1,0,0" Padding="12,8" Margin="0,12,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Save" Click="SaveButton_Click" Width="90" Padding="12,6"
                IsDefault="True" Margin="0,0,8,0"
                Background="#9C27B0" Foreground="White" FontWeight="SemiBold"/>
        <Button Content="Cancel" Click="CancelButton_Click" Width="90" Padding="12,6" IsCancel="True"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
