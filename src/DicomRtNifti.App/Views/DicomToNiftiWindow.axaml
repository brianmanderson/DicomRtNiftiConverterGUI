<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Dicom_RT_images_Csharp.Views.DicomToNiftiWindow"
        Title="DICOM → NIfTI" Width="960" Height="640"
        WindowStartupLocation="CenterScreen">
  <StackPanel Margin="24" Spacing="8">
    <TextBlock Text="DICOM → NIfTI" FontSize="18" FontWeight="Bold"/>
    <TextBlock TextWrapping="Wrap" Foreground="#555"
               Text="Avalonia port of the forward workflow is in progress (Phase 4). The conversion logic already runs cross-platform via the headless CLI (DicomRtNifti.Cli --forward)."/>
  </StackPanel>
</Window>
