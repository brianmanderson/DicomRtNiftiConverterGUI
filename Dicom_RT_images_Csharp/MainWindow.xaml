<Window x:Class="Dicom_RT_images_Csharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dicom_RT_images_Csharp"
        xmlns:vm="clr-namespace:Dicom_RT_images_Csharp.ViewModels"
        xmlns:conv="clr-namespace:Dicom_RT_images_Csharp.Converters"
        mc:Ignorable="d"
        Title="DICOM RT to NIfTI Converter" Height="850" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="#1976D2" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Help"
                        Command="{Binding OpenHelpCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        VerticalAlignment="Center" Padding="14,6" Cursor="Hand"
                        Background="White" Foreground="#1976D2" FontWeight="SemiBold"
                        FontSize="13" MinWidth="80" BorderThickness="0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DICOM to NIfTI Converter" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Scan DICOM directories, select patients and series, convert to NIfTI format"
                               FontSize="12" Foreground="#BBDEFB" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Input/Output/Scan Toolbar -->
        <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Input Row -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Input:" VerticalAlignment="Center"
                               FontWeight="Medium" Foreground="#555555"/>
                    <TextBox Grid.Column="1" Text="{Binding InputFolder, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="6,4"/>
                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseInputCommand}"
                            Style="{StaticResource ActionButtonStyle}" Margin="8,0,0,0"/>
                </Grid>

                <!-- Output Row -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Output:" VerticalAlignment="Center"
                               FontWeight="Medium" Foreground="#555555"/>
                    <TextBox Grid.Column="1" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="6,4"/>
                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseOutputCommand}"
                            Style="{StaticResource ActionButtonStyle}" Margin="8,0,0,0"/>
                </Grid>

                <!-- Scan/Cancel/Progress Row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Scan" Command="{Binding ScanCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#4CAF50" Foreground="White" FontWeight="SemiBold"
                            MinWidth="100"/>
                    <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                            Style="{StaticResource ActionButtonStyle}"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0">
                        <ProgressBar Value="{Binding ProgressValue}" Minimum="0" Maximum="100"
                                     Height="18" Width="400" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis"
                                   Foreground="#666666"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content: TreeView + Right Side Panel -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- TreeView Panel -->
            <Border Grid.Column="0" Background="White" BorderBrush="#DDDDDD"
                    BorderThickness="1" CornerRadius="4" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TreeView Header -->
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#EEEEEE"
                            BorderThickness="0,0,0,1" Padding="12,8"
                            CornerRadius="4,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Patient / Study / Series" FontWeight="SemiBold"
                                       FontSize="13" Foreground="#333333" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Content="Select All?"
                                      IsChecked="{Binding AllPatientsSelected}"
                                      VerticalAlignment="Center" FontSize="12"
                                      Foreground="#555555"/>
                        </Grid>
                    </Border>

                    <!-- TreeView -->
                    <TreeView Grid.Row="1" ItemsSource="{Binding Patients}"
                              BorderThickness="0" Background="Transparent" Padding="8">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <!-- Patient Level -->
                            <HierarchicalDataTemplate DataType="{x:Type vm:PatientGroupViewModel}"
                                                      ItemsSource="{Binding Studies}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,6,0"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="[P]" Margin="0,0,6,0" FontSize="12"
                                               Foreground="#1976D2" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- Study Level -->
                            <HierarchicalDataTemplate DataType="{x:Type vm:StudyGroupViewModel}"
                                                      ItemsSource="{Binding ImageSeries}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="[S]" Margin="0,0,6,0" FontSize="11"
                                               Foreground="#FF9800" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayName}" FontStyle="Italic"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- Series Level -->
                            <DataTemplate DataType="{x:Type vm:SeriesGroupViewModel}">
                                <StackPanel Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,6,0"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="[CT]" Margin="0,0,6,0" FontSize="11"
                                                   Foreground="#4CAF50" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- ROI Names from linked RTSTRUCT -->
                                    <Expander Header="ROI Names" Margin="20,2,0,0"
                                              Visibility="{Binding HasLinkedRtStruct, Converter={StaticResource BoolToVis}}"
                                              IsExpanded="{Binding IsExpanded}">
                                        <ItemsControl ItemsSource="{Binding RoiNames}" Margin="16,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#555555" FontSize="11"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Right Side Panel -->
            <Border Grid.Column="1" Background="White" BorderBrush="#DDDDDD"
                    BorderThickness="1" CornerRadius="4" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Export Options" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Data to Export:" FontWeight="Medium"
                                   Margin="0,0,0,8" Foreground="#555555"/>

                        <CheckBox Content="Export Images" IsChecked="{Binding ExportImages}"
                                  Style="{StaticResource CheckBoxStyle}"/>
                        <CheckBox Content="Include Structures" IsChecked="{Binding IncludeStructures}"
                                  Style="{StaticResource CheckBoxStyle}"/>
                        <CheckBox Content="Include Dose" IsChecked="{Binding IncludeDose}"
                                  Style="{StaticResource CheckBoxStyle}"/>

                        <Separator Margin="0,12"/>

                        <CheckBox Content="Only export specific ROIs?"
                                  IsChecked="{Binding OnlyExportSpecificRois}"
                                  Style="{StaticResource CheckBoxStyle}" Margin="4,8"/>

                        <Button Content="Edit ROI Associations..."
                                Command="{Binding ManageAssociationsCommand}"
                                Padding="12,8" Margin="4,4,4,4" FontSize="13" Cursor="Hand"
                                Background="#2196F3" Foreground="White" FontWeight="SemiBold"/>

                        <Button Content="Select ROIs for Export..."
                                Command="{Binding SelectRoisCommand}"
                                IsEnabled="{Binding OnlyExportSpecificRois}"
                                Padding="12,8" Margin="4,4,4,12" FontSize="13" Cursor="Hand"
                                Background="#FF9800" Foreground="White" FontWeight="SemiBold"/>

                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666666" Margin="4,0,4,4">
                            ROI Associations always apply — matching ROIs are renamed to their canonical names during export.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666666" Margin="4,0,4,0">
                            When checked, only ROIs matching associations are exported. Use "Select ROIs for Export" to choose which ROIs to include. Patients missing all selected ROIs are automatically de-selected.
                        </TextBlock>

                        <Separator Margin="0,12"/>

                        <CheckBox Content="Specify Output Spacing"
                                  IsChecked="{Binding SpecifyOutputSpacing}"
                                  Style="{StaticResource CheckBoxStyle}" Margin="4,8"/>

                        <Button Content="Specify Output..."
                                Command="{Binding OpenOutputSpacingCommand}"
                                IsEnabled="{Binding SpecifyOutputSpacing}"
                                Padding="12,8" Margin="4,4,4,4" FontSize="13" Cursor="Hand"
                                Background="#9C27B0" Foreground="White" FontWeight="SemiBold"/>

                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666666" Margin="4,4,4,0">
                            When enabled, all exports (image, dose, masks) are resampled to the specified X/Y/Z voxel size. Image and dose use linear interpolation; structure masks use nearest-neighbor.
                        </TextBlock>

                        <Separator Margin="0,12"/>

                        <CheckBox Content="Anonymize export?"
                                  IsChecked="{Binding AnonymizeExport}"
                                  Style="{StaticResource CheckBoxStyle}" Margin="4,8"/>

                        <Button Content="Edit Anonymization Key..."
                                Command="{Binding OpenAnonymizationKeyEditorCommand}"
                                IsEnabled="{Binding AnonymizeExport}"
                                Padding="12,8" Margin="4,4,4,12" FontSize="13" Cursor="Hand"
                                Background="#2196F3" Foreground="White" FontWeight="SemiBold"/>

                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666666" Margin="4,0,4,0">
                            When checked, exports use integer folder IDs instead of patient names. A CSV manifest and AnonymizationKey.json track all mappings across sessions.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom Action Bar + Log -->
        <Border Grid.Row="3" Background="White" BorderBrush="#DDDDDD" BorderThickness="1"
                CornerRadius="4" Margin="12,0,12,0" Padding="12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Convert Selected"
                            Command="{Binding ConvertSelectedCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#1976D2" Foreground="White" FontWeight="SemiBold"
                            MinWidth="140"/>
                    <Button Grid.Column="1" Content="Export MetaData"
                            Command="{Binding ExportMetaDataCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#4CAF50" Foreground="White" FontWeight="SemiBold"
                            MinWidth="140"/>
                    <Button Grid.Column="2" Content="Settings..."
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource ActionButtonStyle}"/>
                </Grid>

                <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto" Height="120"
                         FontFamily="Consolas" FontSize="11"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Background="#FAFAFA" BorderBrush="#E0E0E0" Padding="8"/>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#E8E8E8" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="12,6">
            <TextBlock Text="{Binding StatusText}" Foreground="#555555" FontSize="11"/>
        </Border>
    </Grid>
</Window>
