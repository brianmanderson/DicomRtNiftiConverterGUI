<Window x:Class="Dicom_RT_images_Csharp.Views.OutputSpacingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Output Spacing" Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="#9C27B0" Padding="16,10">
            <TextBlock Text="Output Voxel Spacing" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
        </Border>

        <!-- Content Panel -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD"
                BorderThickness="1" CornerRadius="4" Margin="12,12,12,0" Padding="16">
            <StackPanel>
                <TextBlock Text="Specify the output voxel size in millimeters. All exported images, doses, and structure masks will be resampled to this spacing."
                           TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#555555"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" FontWeight="Medium"/>
                    <TextBox Grid.Column="1" x:Name="XTextBox" VerticalContentAlignment="Center"
                             Padding="6,4" BorderBrush="#CCCCCC"/>
                    <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#555555"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Y:" VerticalAlignment="Center" FontWeight="Medium"/>
                    <TextBox Grid.Column="1" x:Name="YTextBox" VerticalContentAlignment="Center"
                             Padding="6,4" BorderBrush="#CCCCCC"/>
                    <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#555555"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Z:" VerticalAlignment="Center" FontWeight="Medium"/>
                    <TextBox Grid.Column="1" x:Name="ZTextBox" VerticalContentAlignment="Center"
                             Padding="6,4" BorderBrush="#CCCCCC"/>
                    <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#555555"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="12,8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Click="SaveButton_Click" Width="90" Padding="12,6"
                        IsDefault="True" Cursor="Hand" Margin="0,0,8,0"
                        Background="#9C27B0" Foreground="White" FontWeight="SemiBold"/>
                <Button Content="Cancel" Click="CancelButton_Click" Width="90" Padding="12,6"
                        IsCancel="True" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
