<Window x:Class="Dicom_RT_images_Csharp.Views.DicomToNiftiHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Help: DICOM to NIfTI" Height="700" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="540"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="Margin" Value="0,18,0,8"/>
        </Style>
        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1976D2" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Help: DICOM → NIfTI" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="How to convert DICOM RT-STRUCT, CT/MR/PT image series, and RT-DOSE into NIfTI files."
                           Foreground="#BBDEFB" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD"
                BorderThickness="1" CornerRadius="4" Margin="12,12,12,0" Padding="20,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource H1}" Text="Workflow overview"/>
                    <TextBlock Style="{StaticResource Body}">
                        This window walks a folder of DICOM files, lets you choose what to export, and writes
                        NIfTI (.nii.gz) outputs for downstream research / analysis use. Image series, structure
                        masks, and dose grids are all supported.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H1}" Text="Step-by-step"/>
                    <TextBlock Style="{StaticResource Body}">
                        <Run FontWeight="SemiBold">1.</Run> Set the <Run FontWeight="SemiBold">Input</Run> folder
                        (the root of your DICOM archive) and the <Run FontWeight="SemiBold">Output</Run> folder
                        (where NIfTI files will be written).
                    </TextBlock>
                    <TextBlock Style="{StaticResource Body}">
                        <Run FontWeight="SemiBold">2.</Run> Click <Run FontWeight="SemiBold">Scan</Run>. The
                        Patient / Study / Series tree fills in. Tick the patients/series you want to export.
                    </TextBlock>
                    <TextBlock Style="{StaticResource Body}">
                        <Run FontWeight="SemiBold">3.</Run> Pick what to write in the
                        <Run FontWeight="SemiBold">Export Options</Run> panel: images, structures, dose. Optionally
                        define ROI associations, restrict to a subset of ROIs, set an output spacing, or
                        anonymize.
                    </TextBlock>
                    <TextBlock Style="{StaticResource Body}">
                        <Run FontWeight="SemiBold">4.</Run> Click <Run FontWeight="SemiBold">Convert Selected</Run>
                        — or use <Run FontWeight="SemiBold">Export MetaData</Run> to produce only a CSV manifest
                        (no .nii.gz files written).
                    </TextBlock>

                    <TextBlock Style="{StaticResource H1}" Text="Top toolbar"/>

                    <TextBlock Style="{StaticResource H2}" Text="Input / Output"/>
                    <TextBlock Style="{StaticResource Body}">
                        Folder paths. <Run FontWeight="SemiBold">Browse...</Run> opens a folder picker. The
                        <Run FontWeight="SemiBold">Input</Run> folder is the root of the DICOM archive (scanned
                        recursively); the <Run FontWeight="SemiBold">Output</Run> folder receives the .nii.gz files.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Scan / Cancel"/>
                    <TextBlock Style="{StaticResource Body}">
                        <Run FontWeight="SemiBold">Scan</Run> walks the input folder, parses each DICOM file, and
                        builds the patient → study → series tree. <Run FontWeight="SemiBold">Cancel</Run> stops
                        the in-progress scan or conversion.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H1}" Text="Patient tree"/>
                    <TextBlock Style="{StaticResource Body}">
                        Three-level checkbox tree. Tick patients/series you want to export. Use
                        <Run FontWeight="SemiBold">Select All?</Run> at the top of the tree to toggle every
                        patient at once.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H1}" Text="Export Options panel"/>

                    <TextBlock Style="{StaticResource H2}" Text="Data to Export"/>
                    <TextBlock Style="{StaticResource Body}">
                        <Run FontWeight="SemiBold">Export Images</Run>: writes the CT/MR/PT image series as
                        <Run FontFamily="Consolas">image.nii.gz</Run> per series.
                        <LineBreak/>
                        <Run FontWeight="SemiBold">Include Structures</Run>: rasterizes RT-STRUCT contours into
                        per-ROI binary masks under <Run FontFamily="Consolas">masks/</Run>.
                        <LineBreak/>
                        <Run FontWeight="SemiBold">Include Dose</Run>: writes RT-DOSE as
                        <Run FontFamily="Consolas">dose.nii.gz</Run>, applying any
                        <Run FontFamily="Consolas">DoseGridScaling</Run>.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Only export specific ROIs?"/>
                    <TextBlock Style="{StaticResource Body}">
                        When ON: only ROIs that match a defined association (or are explicitly selected via the
                        ROI Selection window) are exported, and matching ROIs are renamed to their canonical
                        names. When OFF: all ROIs are exported and unmatched ones keep their original names —
                        but matched ones are still renamed.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Edit ROI Associations..."/>
                    <TextBlock Style="{StaticResource Body}">
                        Define alias sets that all map to one canonical name. Example:
                        <Run FontFamily="Consolas">Target</Run> = {<Run FontFamily="Consolas">CTV</Run>,
                        <Run FontFamily="Consolas">GTV</Run>, <Run FontFamily="Consolas">PTV</Run>}. During export,
                        any DICOM ROI matching one of those aliases is renamed to <Run FontFamily="Consolas">Target</Run>.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Select ROIs for Export..."/>
                    <TextBlock Style="{StaticResource Body}">
                        Enabled when "Only export specific ROIs?" is checked. Lists every canonical ROI name
                        discovered in the scan and lets you tick the subset to export. Patients without any
                        matching ROI are auto-deselected.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Specify Output Spacing"/>
                    <TextBlock Style="{StaticResource Body}">
                        When ON, all exported volumes (image, dose, masks) are resampled to a uniform voxel
                        spacing in mm. Linear interpolation for image and dose; nearest-neighbor for masks.
                        Click <Run FontWeight="SemiBold">Specify Output...</Run> to set X/Y/Z spacing.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Anonymize export?"/>
                    <TextBlock Style="{StaticResource Body}">
                        Replaces patient identifiers with deterministic integer IDs (saltable hash) and writes
                        a <Run FontFamily="Consolas">AnonymizationKey.json</Run> linking IDs back to the originals.
                        <Run FontWeight="SemiBold">Edit Anonymization Key...</Run> opens the key for inspection.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H1}" Text="Bottom action bar"/>

                    <TextBlock Style="{StaticResource H2}" Text="Convert Selected"/>
                    <TextBlock Style="{StaticResource Body}">
                        Runs the full export (images, structures, dose) for every selected series with the
                        current Export Options applied. Writes a CSV manifest summarizing each exported series
                        + ROI volumes.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Export MetaData"/>
                    <TextBlock Style="{StaticResource Body}">
                        Generates only the CSV manifest (
                        <Run FontFamily="Consolas">export_manifest_meta.csv</Run>) — patient ID, study/series
                        UIDs, voxel spacing, and ROI volumes (if Include Structures is on) — without writing any
                        .nii.gz files. Useful for inventory passes.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H2}" Text="Settings..."/>
                    <TextBlock Style="{StaticResource Body}">
                        Per-app settings: default output directory, auto-open after conversion, anonymization
                        salt, etc.
                    </TextBlock>

                    <TextBlock Style="{StaticResource H1}" Text="Tips"/>
                    <TextBlock Style="{StaticResource Body}">
                        • A status bar at the bottom of the main window shows progress messages.<LineBreak/>
                        • Closing the window returns you to the launcher; in-memory state (last folder, options) is retained.<LineBreak/>
                        • For large archives, consider scanning a subset first — Scan walks <Run FontStyle="Italic">every</Run>
                          file in the folder.
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="12,8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" Click="CloseButton_Click"
                        Width="90" Padding="12,6" IsCancel="True" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
