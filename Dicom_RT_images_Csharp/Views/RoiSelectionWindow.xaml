<Window x:Class="Dicom_RT_images_Csharp.Views.RoiSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select ROIs for Export" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="PanelButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Blue Header Bar -->
        <Border Grid.Row="0" Background="#2196F3" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Select ROIs for Export" FontSize="16"
                           FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Choose which ROIs to include. Patients missing all selected ROIs will be de-selected."
                           FontSize="11" Foreground="#BBDEFB" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Two-column layout: checklist (left) + summary (right) -->
        <Grid Grid.Row="1" Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- Left: ROI Checklist with search -->
            <Border Grid.Column="0" Background="White" BorderBrush="#DDDDDD"
                    BorderThickness="1" CornerRadius="4" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Select All header -->
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#EEEEEE"
                            BorderThickness="0,0,0,1" Padding="12,8"
                            CornerRadius="4,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" Content="Select All"
                                      IsChecked="{Binding AllSelected}"
                                      FontWeight="SemiBold" FontSize="13" Foreground="#333333"/>
                            <TextBlock Grid.Column="1" Text="Patients"
                                       FontWeight="Medium" FontSize="11" Foreground="#999999"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                        </Grid>
                    </Border>

                    <!-- Search box -->
                    <TextBox Grid.Row="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="8,8,8,4" Padding="6,4" BorderBrush="#CCCCCC"
                             VerticalContentAlignment="Center"/>

                    <!-- Scrollable list of ROI checkboxes -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="4">
                        <ItemsControl ItemsSource="{Binding FilteredRoiItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="12,4,12,4">
                                        <CheckBox.Content>
                                            <TextBlock Text="{Binding DisplayText}" FontSize="12"
                                                       Foreground="#333333"/>
                                        </CheckBox.Content>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: Selected ROIs Summary -->
            <Border Grid.Column="1" Background="White" BorderBrush="#DDDDDD"
                    BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#EEEEEE"
                            BorderThickness="0,0,0,1" Padding="10,8"
                            CornerRadius="4,4,0,0">
                        <TextBlock Text="Selected ROIs" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#333333"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="4">
                        <ItemsControl ItemsSource="{Binding SelectedSummaryItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F5F5" BorderBrush="#E0E0E0"
                                            BorderThickness="1" CornerRadius="3"
                                            Margin="4,2" Padding="8,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CanonicalName}"
                                                       FontWeight="Medium" FontSize="12"
                                                       Foreground="#333333" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayText}"
                                                       FontSize="11" Foreground="#888888"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Info text -->
        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="11" Foreground="#666666"
                   Margin="16,8,16,0">
            ROI names are shown after resolving aliases through your ROI Associations.
            Patients that do not contain any of the selected ROIs will be automatically de-selected for export.
        </TextBlock>

        <!-- Bottom Buttons -->
        <Border Grid.Row="3" Background="#F0F0F0" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="12,8" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click"
                        Style="{StaticResource PanelButtonStyle}"/>
                <Button Content="Confirm" Click="ConfirmButton_Click"
                        Style="{StaticResource PanelButtonStyle}"
                        Background="#1976D2" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
