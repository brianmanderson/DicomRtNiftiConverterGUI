<Window x:Class="Dicom_RT_images_Csharp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" Height="220" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <!-- Default output directory -->
        <TextBlock Text="Default Output Directory:" Margin="0,0,0,4"/>
        <DockPanel Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseOutput_Click"
                    Width="80" Margin="4,0,0,0"/>
            <TextBox x:Name="OutputDirTextBox" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Auto-open after conversion -->
        <CheckBox x:Name="AutoOpenCheckBox" Content="Open output folder after conversion"
                  Margin="0,0,0,8"/>

        <!-- Export unmatched ROIs -->
        <CheckBox x:Name="ExportUnmatchedCheckBox"
                  Content="Export unmatched ROIs when no association is defined (uses original names)"
                  Margin="0,0,0,24"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Click="SaveButton_Click" Width="80" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Cancel" Click="CancelButton_Click" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
